<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ manifest.run_id }}</title>
  <link rel="stylesheet" href="../../../reports/static/styles.css" />
</head>
<body>
  <main>
    <section class="card">
      <h1 style="margin:0 0 6px 0; font-size:1.2rem;">Run report</h1>
      <div><strong>{{ manifest.run_id }}</strong></div>
      <div class="badge {{ 'ok' if manifest.status == 'completed' else 'bad' }}">{{ manifest.status }}</div>
      <p style="margin:.5rem 0 0 0; color:var(--muted);">SHA {{ manifest.git_sha }} · Branch {{ manifest.branch }}</p>
      <div class="cta-row">
        <a class="button-link" href="../artifacts.zip" download>Download all artifacts (.zip)</a>
        <a class="button-link secondary" href="../artifacts/index.html">Browse all artifacts</a>
        <a class="button-link secondary" href="../">Open run folder</a>
      </div>
    </section>

    <section class="card">
      <h2 style="margin-top:0">Top metrics</h2>
      <div class="grid">
        {% for k, v in metrics.items() %}
          <div>
            <div style="color:var(--muted)">{{ k }}</div>
            <div class="metric">{{ v }}</div>
          </div>
        {% endfor %}
      </div>
    </section>

    <section class="card">
      <h2 style="margin-top:0">Execution proof</h2>
      <ul>
        <li><strong>Backend:</strong> {{ manifest.backend }}</li>
        <li><strong>Attempts:</strong> {{ manifest.orchestration.attempts }} / {{ manifest.orchestration.max_retries + 1 }} max tries</li>
        <li><strong>Queue timeout:</strong> {{ manifest.orchestration.queue_timeout_seconds }} seconds</li>
        {% if manifest.orchestration.last_wait_result %}
        <li><strong>Modal service used:</strong> {{ manifest.orchestration.last_wait_result.modal_service_used }}</li>
        {% if manifest.orchestration.last_wait_result.requested_hardware %}
        <li><strong>Requested hardware:</strong> {{ manifest.orchestration.last_wait_result.requested_hardware.instance_type }} / {{ manifest.orchestration.last_wait_result.requested_hardware.accelerator }}</li>
        {% endif %}
        {% if manifest.orchestration.last_wait_result.runner_wait_seconds is defined %}
        <li><strong>Runner wait time:</strong> {{ manifest.orchestration.last_wait_result.runner_wait_seconds }} seconds</li>
        {% endif %}
        {% endif %}
        {% if collect_metadata %}
        <li><strong>Modal mode:</strong> {{ collect_metadata.mode }}</li>
        <li><strong>Modal job id:</strong> {{ collect_metadata.job_id }}</li>
        {% if collect_metadata.missing_credentials %}
        <li><strong>Missing credentials:</strong> {{ collect_metadata.missing_credentials|join(', ') }}</li>
        {% endif %}
        {% endif %}
      </ul>
      <p class="muted">
        Verify in artifacts: <code>logs/train.log</code>, <code>logs/eval.log</code>, <code>logs/orchestration.log</code>,
        and <code>collect_metadata.json</code> (Modal).
      </p>
    </section>

    <section class="card">
      <h2 style="margin-top:0">Summary</h2>
      <pre>{{ summary_md }}</pre>
    </section>

    <section class="card">
      <h2 style="margin-top:0">Artifacts</h2>
      <p class="muted">Tip for iPhone Safari: long-press any artifact link to save/share quickly.</p>
      <p><a class="button-link secondary" href="../artifacts/index.html">Open full artifact browser</a></p>
      <ul>
        <li><a href="../metrics.csv" download>metrics.csv</a></li>
        <li><a href="../metrics.json" download>metrics.json</a></li>
        <li><a href="../config_frozen.yaml" download>config_frozen.yaml</a></li>
        <li><a href="../logs/train.log" download>train.log</a></li>
        <li><a href="../logs/eval.log" download>eval.log</a></li>
        <li><a href="../logs/comparators.log" download>comparators.log</a></li>
        <li><a href="../case_metrics.csv" download>case_metrics.csv</a></li>
        <li><a href="../comparator_metrics.csv" download>comparator_metrics.csv</a></li>
        <li><a href="../comparator_metrics.json" download>comparator_metrics.json</a></li>
        <li><a href="../plotly/training_curves.html">training_curves.html</a></li>
        <li><a href="../plotly/embedding_projection.html">embedding_projection.html</a></li>
      </ul>
    </section>

    <section class="card">
      <h2 style="margin-top:0">Figures</h2>
      <img src="../figures/loss_curve.png" alt="loss curve" />
      <img src="../figures/confusion_matrix.png" alt="confusion matrix" />
    </section>

    <section class="card">
      <h2 style="margin-top:0">Next experiments</h2>
      <ul>
        <li>Run seed sweep: 13, 21, 89.</li>
        <li>Test higher learning rate: 0.003.</li>
        <li>Compare local backend output with future Modal backend.</li>
      </ul>
    </section>
  </main>
</body>
</html>
