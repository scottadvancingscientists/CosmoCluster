<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ compare_id }}</title>
  <link rel="stylesheet" href="../../../reports/static/styles.css" />
</head>
<body>
<main>
  <section class="card">
    <h1 style="margin-top:0">Run comparison</h1>
    <div>{{ compare_id }}</div>
    <p>Best run: <strong>{{ best_run_id }}</strong></p>
  </section>
  <section class="card table-wrap">
    <table>
      <thead>
      <tr><th>run_id</th><th>status</th><th>accuracy</th><th>f1</th><th>loss</th><th>delta_to_best</th></tr>
      </thead>
      <tbody>
      {% for r in rows %}
      <tr>
        <td>{{ r.run_id }}</td><td>{{ r.status }}</td><td>{{ r.accuracy }}</td><td>{{ r.f1 }}</td><td>{{ r.loss }}</td>
        <td>{{ "0.0" if r.run_id == best_run_id else "-" }}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
</main>
</body>
</html>
